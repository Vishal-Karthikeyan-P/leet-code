/**
Valid Paranthesis
Given a string s containing just the characters '(', ')', '{', '}', '[' and ']', determine if the input string is valid.

An input string is valid if:

    Open brackets must be closed by the same type of brackets.
    Open brackets must be closed in the correct order.
    Every close bracket has a corresponding open bracket of the same type.

Input: s = "()[]{}"

Output: true

Input: s = "(]"

Output: false

Input: s = "([)]"

Output: false

**/

#include <ctype.h>
bool isValid(char* s) {
    char stack[strlen(s)];
    int i=0,j=0;
    while(s[i]!='\0')
    {
        if(s[i]=='(' || s[i]=='[' || s[i]=='{')
            stack[j++]=s[i];
        if(s[i]==')')
            if(j==0 || stack[j-1]!='(')
                return false;
            else
                --j;
        if(s[i]==']')
            if(j==0 || stack[j-1]!='[')
                return false;
            else
                --j;
        if(s[i]=='}')
            if(j==0 || stack[j-1]!='{')
                return false;
            else
                --j;
        i++;
    }
    return (j==0);
}
